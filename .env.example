# Copie este arquivo para .env e preencha os valores

# URL de conexão com o PostgreSQL
# Formato: postgresql://USUARIO:SENHA@HOST:PORTA/NOME_DO_BANCO
DATABASE_URL="postgresql://postgres:suasenha@localhost:5432/meu_banco"

# Segredo para assinar os tokens JWT (use uma string longa e aleatória)
JWT_SECRET="troque-por-uma-chave-secreta-bem-longa-e-aleatoria"

# Tempo de expiração do token (ex: 1d, 7d, 24h)
JWT_EXPIRES_IN="7d"

# Porta do servidor
PORT=3001
